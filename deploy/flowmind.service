[Unit]
Description=FlowMind - AI Workflow Generation Platform
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/flowmind
EnvironmentFile=/opt/flowmind/.env
ExecStart=/opt/flowmind/venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
